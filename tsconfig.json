{
  "compilerOptions": {
    "target": "ES2021",
    "useDefineForClassFields": true,
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    // P5: تفعيل تدريجي — خطوتان آمنتان بلا كسر
    // (strict: true يتطلب إزالة 450+ استخدام لـ any و415 catch بلا تحديد نوع أولاً)
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": []
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "src/features/inventory/components/**/*",
    "src/features/testing/**/*",
    "src/features/reports/proxy-service/**/*",
    "src/features/reports/routes/**/*",
    "src/services/warehouse-service.ts",
    "src/services/stock-adjustment-service.ts",
    "src/services/valuation/**/*",
    "src/domain/**/*",
    "src/utils/**/*"
  ],
  "references": [
    { "path": "./tsconfig.node.json" }
  ]
}
